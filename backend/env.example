# AI Provider Configuration (EXCLUSIVELY controls provider selection - no code changes needed)
# Options: ollama, openai, auto
AI_PROVIDER=auto

# OpenAI Configuration (for deployment / cloud-backed runtime)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=15

# Ollama Configuration (for thesis defense / offline local demo)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=60

# Fallback Settings
FALLBACK_TO_OLLAMA=true

# Safety Settings
MAX_INPUT_LENGTH=3000
